# Anthropic. Required unless MOCK_LLM=true.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: OpenAI for real Whisper. Not required. Stub is deterministic.
OPENAI_API_KEY=

# Mongo + Redis (defaults work with `pnpm infra:up`).
MONGODB_URI=mongodb://localhost:27017/afters
REDIS_URL=redis://localhost:6379

# Agent runtime.
# MOCK_LLM=true bypasses Anthropic and returns canned outputs for scenarios.
MOCK_LLM=false

# Shortens the 48h mutual-reveal timeout for demo purposes.
# Set to 240 (4 minutes) for the video. Long enough for a reviewer to read
# the "awaiting second response" state on the graph; short enough that a
# live session that goes ghosted resolves to timed_out within the demo.
TIMEOUT_SECONDS_OVERRIDE=240

# Service URLs used by server-side code.
MESSAGING_BASE_URL=http://localhost:3001
ORCHESTRATOR_BASE_URL=http://localhost:8000

# Dashboard-facing (NEXT_PUBLIC_ prefix exposes to browser).
NEXT_PUBLIC_ORCHESTRATOR_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MESSAGING_BASE_URL=http://localhost:3001

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://afters.ditto.local/schemas/group_queue.schema.json",
  "title": "GroupQueueEntry",
  "type": "object",
  "required": ["_id", "user_id", "session_id", "campus", "tags", "status", "created_at"],
  "properties": {
    "_id": { "type": "string" },
    "user_id": { "type": "string" },
    "session_id": { "type": "string" },
    "campus": { "type": "string", "enum": ["UC Berkeley", "UC San Diego", "UCLA", "USC", "UC Davis", "San Jose State"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["queued", "matched", "canceled"] },
    "group_event_id": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}

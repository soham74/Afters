{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://afters.ditto.local/schemas/second_date.schema.json",
  "title": "SecondDate",
  "type": "object",
  "required": ["_id", "session_id", "proposed_venues", "proposed_time_slots", "user_a_confirmed", "user_b_confirmed", "created_at"],
  "properties": {
    "_id": { "type": "string" },
    "session_id": { "type": "string" },
    "proposed_venues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["venue_id", "reason"],
        "properties": {
          "venue_id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "proposed_time_slots": { "type": "array", "items": { "type": "string" } },
    "confirmed_venue_id": { "type": ["string", "null"] },
    "confirmed_time": { "type": ["string", "null"] },
    "user_a_confirmed": { "type": "boolean" },
    "user_b_confirmed": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
